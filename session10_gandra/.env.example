# session10_gandra — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required — OpenAI API key (used for gpt-4o-mini in all LLM nodes)
OPENAI_API_KEY=sk-your-key-here

# Optional — Langfuse tracing (uncomment if you want observability)
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
