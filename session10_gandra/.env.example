# session10_gandra — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required — OpenAI API key (used for gpt-4o-mini in all LLM nodes)
OPENAI_API_KEY=sk-your-key-here

# ── Tracing (opciono — oba mogu raditi istovremeno) ──────────────

# LangSmith — native LangChain/LangGraph tracing (zero-code, automatic)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=cv-tailoring
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Langfuse — open-source LLM tracing (via callback)
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com          # aka LANGFUSE_BASE_URL
